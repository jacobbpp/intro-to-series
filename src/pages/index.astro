---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import fontsCSS from '../styles/fonts.js';
import '../styles/global.css';
import { getCollection } from 'astro:content';
import FormattedDate from '../components/FormattedDate.astro';
import { Image } from 'astro:assets';
import readingTime from 'reading-time';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style is:inline>{fontsCSS}</style>
    <style>
      main {
        width: 960px;
        max-width: 100%;
        margin: 0 auto;
        padding: 2rem 1rem;
      }
      ul {
        display: flex;
        flex-wrap: wrap;
        gap: 2rem;
        list-style: none;
        margin: 0;
        padding: 0;
        justify-content: center;
      }
      ul li {
        width: calc(50% - 1rem);
        text-align: center;
      }
      ul li:first-child {
        width: 100%;
      }
      ul li img {
        width: 100%;
        height: auto;
        border-radius: 12px;
      }
      ul li a {
        text-decoration: none;
        color: inherit;
        display: block;
      }
      .title {
        margin: 0.5em 0 0 0;
        font-size: 1.5em;
        color: rgb(var(--black));
      }
      .meta {
        margin: 0.25em 0 0 0;
        font-size: 0.9em;
        color: rgb(var(--gray));
      }
      @media (max-width: 720px) {
        ul li {
          width: 100%;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1 style="text-align: center;">The Intro To Series</h1>
      <p style="text-align: center;">
        Bite-sized deep dives into modern tech.
      </p>

      {posts.length > 0 && (
        <section>
          <h2 style="text-align: center;">Latest Posts</h2>
          <ul>
            {posts.map((post) => {
              const stats = readingTime(post.body);
              return (
                <li>
                  <a href={`${base}blog/${post.id}/`}>
                    {post.data.heroImage && (
                      <Image
                        width={720}
                        height={360}
                        src={post.data.heroImage}
                        alt=""
                        sizes="(max-width: 720px) 100vw, 720px"
                      />

                    )}
                    <h4 class="title">{post.data.title}</h4>
                    <p class="meta">
                      <FormattedDate date={post.data.pubDate} /> · {stats.text}
                    </p>
                  </a>
                </li>
              );
            })}
          </ul>
        </section>
      )}

      <section class="about-section" style="text-align: center; margin-top: 3rem;">
        <h2>A quick intro to Jacob</h2>
        <p style="margin: 0 auto;">
          Jacob Reilly-Cooper writes about tech for people who’d rather not read
          the manual. Whether it’s quantum computing, modern DevOps, or AI, he
          breaks down the intimidating into the understandable, and occasionally,
          the entertaining.
        </p>
    
      </section>
    </main>
    <Footer />
  </body>
</html>
